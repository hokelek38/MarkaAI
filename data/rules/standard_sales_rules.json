  "metadata": {
    "name": "MarkaAI Standart Satış Muhasebe Kuralları",
    "version": "0.1.0",
    "status": "development",
    "last_reviewed": "2026-07-11",
    "description": "Standart yurt içi mal ve hizmet satış faturaları için açıklanabilir muhasebe fişi öneri kuralları.",
    "primary_basis": [
      "1 Sıra No.lu Muhasebe Sistemi Uygulama Genel Tebliği",
      "3065 sayılı Katma Değer Vergisi Kanunu",
      "Katma Değer Vergisi Genel Uygulama Tebliği"
    ],
    "warning": "Bu kurallar yalnızca standart KDV'li yurt içi satış işlemlerinde kullanılabilir. Tevkifat, istisna, ihracat, ihraç kayıtlı teslim, iade, özel matrah ve benzeri özel işlemlere uygulanamaz. Mali müşavir onayı olmadan kayıt kesinleştirilemez."
  },

  "rules": [
    {
      "rule_id": "STANDARD_SALE_CREDIT_GOODS",
      "priority": 100,
      "enabled": true,
      "description": "Vadeli yurt içi ticari mal veya mamul satışı",
      "transaction_codes": [
        "STANDARD_SALE"
      ],
      "conditions": {
        "direction": [
          "sale"
        ],
        "tax_scenario": [
          "standard_vat"
        ],
        "payment_type": [
          "credit"
        ],
        "sale_content_type": [
          "goods",
          "trade_goods",
          "finished_goods"
        ]
      },
      "entries": {
        "debit": [
          {
            "account": "120",
            "amount_source": "total_amount",
            "description": "Müşteriden doğan senetsiz ticari alacak"
          }
        ],
        "credit": [
          {
            "account": "600",
            "amount_source": "subtotal",
            "description": "Yurt içi satış hasılatı"
          },
          {
            "account": "391",
            "amount_source": "vat_amount",
            "description": "Satış üzerinden hesaplanan KDV",
            "include_when": {
              "vat_amount_positive": true
            }
          }
        ]
      },
      "confidence": 95,
      "requires_customer": true,
      "requires_payment_type_confirmation": true,
      "requires_vat_validation": true,
      "requires_professional_approval": true
